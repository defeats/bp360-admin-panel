<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bp360_admin_panel.ReviewsPage"
             Title="">
    
    <Grid RowDefinitions="Auto, Auto, *">

        <VerticalStackLayout Grid.Row="0" 
                           HorizontalOptions="Center" 
                           Spacing="10" 
                           Padding="0,20">
            <Button x:Name="EditReview" Text="Módosítás" Clicked="EditReview_Clicked" BackgroundColor="{StaticResource bp360Button}" TextColor="White" FontAttributes="Bold"/>
            <Button x:Name="DeleteReview" Text="Törlés" Clicked="DeleteReview_Clicked" BackgroundColor="{StaticResource bp360Button}" TextColor="White" FontAttributes="Bold"/>
        </VerticalStackLayout>

        <Label Grid.Row="1" 
           Text="Vélemények listája" 
           FontSize="20" 
           HorizontalOptions="Center" 
           Margin="0,0,0,10" />

        <CollectionView Grid.Row="2" x:Name="ReviewsListView" SelectionMode="Single">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                    Padding="15"
                    Stroke="DarkOrange"
                    StrokeThickness="0.3"
                    StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout>
                            <Label>
                                <Label.Text>
                                    <MultiBinding StringFormat="{}ID: {0} | Felhasználó ID: {1} | Hely ID: {2} | {3} csillag">
                                        <Binding Path="id" />
                                        <Binding Path="user_id" />
                                        <Binding Path="place_id" />
                                        <Binding Path="star" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                            <Label Text="{Binding comment}" TextColor="DarkOrange"/>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>