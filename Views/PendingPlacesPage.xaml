<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bp360_admin_panel.PendingPlacesPage"
             Title="">
    <VerticalStackLayout>
        <Grid RowDefinitions="Auto, Auto, *">

            <VerticalStackLayout Grid.Row="0" 
                           HorizontalOptions="Center" 
                           Spacing="10" 
                           Padding="0,20">
                <Button x:Name="ApprovePlace" Text="Elfogadás" Clicked="ApprovePlace_Clicked" BackgroundColor="LightGreen" TextColor="White" FontAttributes="Bold"/>
                <Button x:Name="RejectPlace" Text="Elutasítás" Clicked="RejectPlace_Clicked" BackgroundColor="#FF7F7F" TextColor="White" FontAttributes="Bold"/>
            </VerticalStackLayout>

            <Label Grid.Row="1" 
           Text="Visszaigazolandó helyek listája" 
           FontSize="20" 
           HorizontalOptions="Center" 
           Margin="0,0,0,10" />

            <CollectionView Grid.Row="2" x:Name="PendingPlacesListView" SelectionMode="Single">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="5" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                    Padding="15"
                    Stroke="DarkOrange"
                    StrokeThickness="0.3"
                    StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout>
                                <Label>
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} | ID: {1} | slug: {2} | E-mail: {3} | Tel: {4} | Cím: {5} {6}">
                                            <Binding Path="name" />
                                            <Binding Path="id" />
                                            <Binding Path="slug" />
                                            <Binding Path="email" />
                                            <Binding Path="phone" />
                                            <Binding Path="post_code" />
                                            <Binding Path="address" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding description}" TextColor="DarkOrange"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </VerticalStackLayout>
</ContentPage>