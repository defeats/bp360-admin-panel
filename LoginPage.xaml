<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="bp360_admin_panel.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Title="">
    
    <VerticalStackLayout 
        Spacing="20" 
        Padding="30"
        VerticalOptions="Center" 
        HorizontalOptions="Center">

        <Label 
            Text="Admin belépés"
            FontSize="28"
            FontAttributes="Bold"
            TextColor="#ff9500"
            HorizontalOptions="Center"
            Margin="0,0,0,10" />

        <Entry 
            x:Name="EmailEntry" 
            Placeholder="E-mail cím" 
            WidthRequest="300"/>

        <Entry 
            x:Name="PasswordEntry" 
            Placeholder="Jelszó" 
            IsPassword="True" 
            WidthRequest="300" />

        <Button 
            Text="Bejelentkezés" 
            Clicked="LoginButton_Clicked" 
            WidthRequest="300" 
            BackgroundColor="#ffaa33"
            TextColor="White" />

    </VerticalStackLayout>
</ContentPage>