<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="bp360_admin_panel.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:bp360_admin_panel"
    Title="bp360_admin_panel">

    <TabBar>
        <ShellContent Title="Betöltés" ContentTemplate="{DataTemplate local:LoadingPage}" Route="loading" />
    </TabBar>

    <TabBar>
        <ShellContent Title="Bejelentkezés" ContentTemplate="{DataTemplate local:LoginPage}" Route="login" />
    </TabBar>

    <TabBar Route="adminpanel">
        <ShellContent Title="Adatok" ContentTemplate="{DataTemplate local:DashboardPage}" />
        <ShellContent Title="Helyek" ContentTemplate="{DataTemplate local:PlacesPage}" />
        <ShellContent Title="Felhasználók" ContentTemplate="{DataTemplate local:UsersPage}" />
    </TabBar>

    <TabBar>
        <ShellContent Title="Hely szerkesztése" ContentTemplate="{DataTemplate local:EditPlacePage}" Route="editplace" />
    </TabBar>

    <TabBar>
        <ShellContent Title="Felhasználó hozzáadása" ContentTemplate="{DataTemplate local:AddUserPage}" Route="adduser" />
    </TabBar>
    
</Shell>
