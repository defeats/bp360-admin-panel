<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="bp360_admin_panel.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:bp360_admin_panel"
    Title="bp360_admin_panel">

    <ShellContent
        Title="Loading"
        ContentTemplate="{DataTemplate local:LoadingPage}"
        Route="loading" />
    
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate local:LoginPage}"
        Route="login" />

    <TabBar Route="adminpanel">
        <ShellContent Title="Dashboard" ContentTemplate="{DataTemplate local:DashboardPage}" />
        <ShellContent Title="Places" ContentTemplate="{DataTemplate local:PlacesPage}" />
        <ShellContent Title="Users" ContentTemplate="{DataTemplate local:UsersPage}" />
    </TabBar>

</Shell>
